#define FinalBattleFlash(character,alivetext,label) "CHECK_ALIVE character; BEQ label 0x0 0xC; CHECK_DEPLOYED character; BEQ label 0x0 0xC; CAM1 character; STAL 20; FlashCursor(character,60); Text(alivetext); LABEL label"

#define FadeToBlack "FADI 16"
#define FadeBackFromBlack "FADU 16"
#define SoundEffect(music) "SOUN music"
#define SFX(music) "SOUN music"

// ReplaceItem(itemID, unitID)
//   Gives itemID to the unit with character ID unitID.
//   If the unit's inventory is full and the item is a weapon/staff, the
//   lowest-ranked non-char-locked weapon/staff is sent to convoy to make room.
//   If all such items have character locks, the new item goes to convoy instead.
//   Non-weapon/staff items go to an empty slot or convoy. Silent (no popup).
//   gEventSlots[1] = itemID (first arg), gEventSlots[2] = unitID (second arg)
#define ReplaceItem(itemID, unitID) "SVAL 1 (itemID); SVAL 2 (unitID); ASMC ReplaceItemASMC|1"

// BuyItem(itemID, unitID)
//   Like ReplaceItem, but deducts the item's full purchase price from party gold
//   first. Does nothing if the party cannot afford it.
//   gEventSlots[1] = itemID (first arg), gEventSlots[2] = unitID (second arg)
#define BuyItem(itemID, unitID) "SVAL 1 (itemID); SVAL 2 (unitID); ASMC BuyItemASMC|1"

// RW here. i stole these from pikmin1211 on feucord from a really old post, so they may be bad
#define LearnSkill(Unit,Skill) "SVAL 0x1 Skill; SVAL 0x2 Unit; ASMC (ASMC_HasSkill|1); BNE 0xED6B 0xC 0x0; ASMC (ASMC_LearnNewSkill|1); LABEL 0xED6B"
#define ForgetSkill(Unit,Skill) "SVAL 0x1 Skill; SVAL 0x2 Unit; ASMC (ASMC_HasSkill|1); BEQ 0xED6C 0xC 0x0; ASMC (ASMC_ForgetSkill|1); LABEL 0xED6C"


#define WarpInCoords(x,y) "SVAL sB ([x,y]); WARP_IN; STAL 0x32; ENDWARP;"
#define WarpOutCoords(x,y) "SVAL sB ([x,y]); WARP_OUT; DISA ([x,y]); STAL 0x32; ENDWARP;"

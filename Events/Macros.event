#define IfHeroMale(label) "SVAL s1 0x1; CHECK_CLASS HeroChar; SSUB sC sC s1; BNE (label) 0xc 0x0;"
#define IfHeroFemale(label) "SVAL s1 0x1; CHECK_CLASS HeroChar; SSUB sC sC s1; BEQ (label) 0xc 0x0;"

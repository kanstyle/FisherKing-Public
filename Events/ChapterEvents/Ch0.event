EventPointerTable(Ch0EventsID, PointerList)

TutorialEventCompletionFlag := 0x10
Stage1SoldierBattled := 0x7
Stage1SoldierBattledLabel := 0x1

Stage2BeganFlag := 0x11
Stage2BeganCheckLabel := 0x11
Stage2StartLabel := 0x2

Stage2SoldierBattled := 0x8
Stage2EndLabel := 0x3

Stage3BeganFlag := 0x14
Stage3StartLabel := 0x13
Stage3CompleteFlag := 0x12
Stage3EndLabel := 0x14

TurnOffCompletionFlagAndEndLabel := 0x8
EndLabel := 0x0

SkipStartEvent := 0x15

#define Ch0BunnyTalkFlag 0x15

PointerList:
	POIN TurnBasedEvents
	POIN CharacterBasedEvents
	POIN LocationBasedEvents
	POIN MiscBasedEvents
	POIN Dunno1 Dunno2 Dunno3 Tutorial
	POIN Traps1 Traps2
	POIN Units1 Units1  //This unit group determines the number and position of deployment slots when there is a prep screen
	POIN $0 $0 $0
	POIN $0 $0 $0
	POIN BeginningScene EndingScene

TurnBasedEvents:
	TurnEventPlayer(0x0,BleedoutChapterTurnEvent,1,255)
	TurnEventPlayer(0x0,HeroGenderFlagTurnEvent,1,255)
	TurnEventPlayer(0x0,WaitTeacher,1,255)
	TurnEventEnemy(0x0,EndChapter,1,255)
	END_MAIN

ALIGN 32
CharacterBasedEvents:
	CharacterEvent(Ch0BunnyTalkFlag,Ch0BunnyPrinceTalk,YoungPrince,Ch0Bunny)
	END_MAIN

MiscBasedEvents:
	CauseGameOverIfLordDies
	AFEV BleedoutFlag BleedoutChapterAlwaysEvent 0x0
	AFEV TutorialEventCompletionFlag TutorialEvent 0x0
	AFEV 0x0 RefreshPrince 0x0
	END_MAIN

LocationBasedEvents:
	END_MAIN

Dunno1:

	END_MAIN

Dunno2:

	END_MAIN

Dunno3:

	END_MAIN

Tutorial:

	END_MAIN

Units1:

	UNIT YoungPrince Noble 0x40 Level(1,Ally,False)     [5,14] 0b 0x0 0x0 0x0 [Rapier] [0x0,0x0,0x0,0x0]
	UNIT
	

EnemyUnits:

Traps1:
	ENDTRAP
	ALIGN 4

Traps2:
	ENDTRAP
	ALIGN 4
	
RefreshPrince:
	UNCR(YoungPrince,AlreadyMoved)
	GetUnitStatus(YoungPrince,YCoord)
	SVAL s1 7
	BGT 0x0 sC s1
		SET_ACTIVE 0x0
		FADI 8
		CAMERA [5,14]
		MOVE 65535 YoungPrince [5,14]
		FADU 8
		Highlight(YoungPrince)
		Text(Ch0WanderOff)
	LABEL 0x0
	
	FlagNotSet(Stage3BeganFlag,0x1)
		GetUnitStatus(YoungTeacher,YCoord)
			SVAL s1 3
			BEQ 0x1 sC s1
				SET_ACTIVE 0x0
				//Text(Ch0TutorialShove)
				MOVE 5 YoungTeacher [3,12]; ENUN
				CursorOn(YoungPrince)
	LABEL 0x1
	NoFade
	ENDA

EndChapter:
	FlagIsSet(Stage3BeganFlag,0x0)
		CALL EndingScene
	LABEL 0x0
	NoFade
	ENDA
	
WaitTeacher:
	FlagNotSet(Stage3BeganFlag,0x0)
		UNCM(YoungTeacher,AlreadyMoved)
	LABEL 0x0
	NoFade
	ENDA

BeginningScene:
	FadeOutMusic
	
	CALL GameStartMenuEvent
	
	FlagNotSet(SkipStartEvent,0x0)
	
	SetBackgroundSlow(ButterflyInverted)
	STAL 60
	
	AllowSkipping
	CenterTextbox(Ch0ButterflyIntro)
	RemoveBackgroundSlow
	
	MusicChange(PMD_MtThunderID)
	SetBackgroundSlow(FogMountains)
	STAL 60
	CenterTextbox(Ch0HighlandsLore)
	RemoveBackgroundSlow
	
	MusicChange(ForbiddenForestID)
	SetBackgroundSlow(Castle_Room)
	BROWNBOXTEXT Ch0OldPrinceBirthdayBrownBox [8,8]
	Text(Ch0OldPrinceBirthday)
	RemoveBackgroundSlow
	MusicChange(PMDSteamCaveID)
	SetBackground(0x35)
	CenterTextbox(Ch0LowlandLore)
	RemoveBackgroundSlow
	
	MusicChange(PMD_MtThunderID)
	CAMERA [2,13]
	FADU 4
	BROWNBOXTEXT Ch0LowlandBrownBox [8,8]
	CameraCursorLocation(2,13,60)
	
	SetBackground(Fort)
	Text(Ch0LowlandsArrival)
	RemoveBackgroundSlow
	FOGVISION 4
	LOAD1 0x1 GreenSoldiers
	ENUN
	SetFlag(Ch0BunnyTalkFlag)
	FADU 4
	
	STAL 60
	LOAD1 0x1 Units1
	ENUN
	STAL 15
	Highlight(YoungPrince)
	Text(Ch0PrinceMonologue)
	
	STAL 30
	LOAD1 0x1 TeacherUnit
	ENUN
	STAL 15
	Highlight(YoungTeacher)
	Text(Ch0TutorialStart)
	CameraCursorLocation(4,12,60)
	CUSE 0x81
	STAL 15
	CenterTextbox(Ch0TutorialStage1ScrollText)
	STAL 15
	MOVE 5 YoungTeacher [3,12]; ENUN
	UNCM(YoungTeacher,AlreadyMoved)
	STAL 15
	CenterTextbox(Ch0TutorialStage1FlankingScrollText)
	CursorOn(YoungPrince)
	LABEL 0x0
	NoFade
	ENDA
	
ALIGN 4
TutorialEvent:
	FlagNotSet(Stage1SoldierBattled,Stage1SoldierBattledLabel)
		Highlight(YoungTeacher)
		Text(Ch0TutorialComeBack) //come back!
		CAMERA [5,14]
		SET_ACTIVE 0x0
		UNCM(YoungPrince, Hide)
		MOVE 5 YoungPrince [5,14]
		ENUN
		UNCR(YoungPrince, AlreadyMoved)
		UNCR(YoungPrince, Hide)
		UNCM(YoungTeacher, AlreadyMoved)
		CursorOn(YoungPrince)
		GOTO TurnOffCompletionFlagAndEndLabel
	
	LABEL Stage1SoldierBattledLabel
	FlagNotSet(Stage2BeganFlag,Stage2StartLabel)
		UNCR(YoungPrince,0x2) //stage 2 begins
		SET_ACTIVE 0x0
		Highlight(YoungTeacher)
		Text(Ch0TutorialStage2)
		CameraCursorLocation(6,12,60)
		CUSN 0x81
		CUSE 0x82
		STAL 15
		CenterTextbox(Ch0TutorialStage2ScrollText)
		SetFlag(Stage2BeganFlag)
		CursorOn(YoungPrince)
		GOTO TurnOffCompletionFlagAndEndLabel
		LABEL Stage2StartLabel
		
	FlagNotSet(Stage2SoldierBattled,Stage2EndLabel)
	FlagIsSet(Stage1SoldierBattled,TurnOffCompletionFlagAndEndLabel)
		Highlight(YoungTeacher)
		Text(Ch0TutorialComeBack) //come back!
		CAMERA [5,14]
		SET_ACTIVE 0x0
		UNCM(YoungPrince, Hide)
		MOVE 5 YoungPrince [5,14]
		ENUN
		UNCR(YoungPrince, AlreadyMoved)
		UNCR(YoungPrince, Hide)
		UNCM(YoungTeacher, AlreadyMoved)
		CursorOn(YoungPrince)
		GOTO TurnOffCompletionFlagAndEndLabel
		LABEL Stage2EndLabel
		
	FlagIsSet(Stage2SoldierBattled,TurnOffCompletionFlagAndEndLabel)
	FlagNotSet(Stage3BeganFlag,Stage3StartLabel)
		SET_ACTIVE 0
		UNCR(YoungPrince,0x2)
		UNCR(YoungTeacher,0x2)
		STAL 45
		CAMERA [2,13]
		
		LOAD1 0x1 OldPrinceUnit
		ENUN
		STAL 30
		Highlight(OldPrince)
		STAL 30
		Text(Ch0OldPrinceAppears)
		
		MOVE 5 YoungPrince [3,13]
		ENUN
		
		Highlight(OldPrince)
		Text(Ch0OldPrinceYoungPrinceTalk)
		SetBackground(ButterflyInverted)
		CenterTextbox(Ch0DontRemember)
		RemoveBackground
		FADU 16
		
		CUSA 0x81
		SetUnitFullHP(0x81)
		CUSA 0x82
		SetUnitFullHP(0x82)
		SetUnitFullHP(YoungPrince)
		
		//set the boys to allies
		SCOORD sB [5,10]
		CUSA UnitAtCoordsSlotB
		SCOORD sB [3,10]
		CUSA UnitAtCoordsSlotB
		SCOORD sB [1,8]
		CUSA UnitAtCoordsSlotB
		SCOORD sB [12,7]
		CUSA UnitAtCoordsSlotB
		SCOORD sB [6,9]
		CUSA UnitAtCoordsSlotB
		SCOORD sB [8,9]
		CUSA UnitAtCoordsSlotB
		SCOORD sB [2,9]
		CUSA UnitAtCoordsSlotB
		SCOORD sB [12,9]
		CUSA UnitAtCoordsSlotB
		CUSA Jerry
		CUSA 0x84
		SetFlag(Stage3BeganFlag)
		UnsetFlag(Ch0BunnyTalkFlag)
		
		CenterTextbox(Ch0DefendAlertScrollText)
		MOVE 5 YoungPrince [5,14]
		
		//stage 3 tutorial
		STAL 60
		Highlight(Jerry)
		STAL 30
		Text(Ch0TutorialStage3)
		SVAL 0x1 Jerry
		SVAL 0x6 0x255
		ASMC ASMC_SelfDamageLikeBomb|1
		ENUN
		
		UNCM(Jerry,0x2)
		UNCR(Jerry,0x1)
		UNCR(Jerry,0x4)
		SetUnitStatus(Jerry,CurrentHP,1)
		SetUnitStatus(Jerry,BadStatusType,0xB) //manually petrify jerry
		
		Text(Ch0JerryNo)
		CenterTextbox(Ch0TutorialStage3ScrollText)
		CursorOn(YoungPrince)
		GOTO TurnOffCompletionFlagAndEndLabel
		LABEL Stage3StartLabel
		
		GOTO EndLabel
		LABEL TurnOffCompletionFlagAndEndLabel
		UnsetFlag(TutorialEventCompletionFlag)
		
	LABEL EndLabel
//Add a bleedout tutorial where a soldier eats some bad food and dies, and needs to be Restored by a priest
	NoFade
	ENDA

ALIGN 4
Ch0BunnyPrinceTalk:
	Text(Ch0BunnyTalk)
	CallMenu(Ch0BunnyMenu)
	BEQ 0 0xC 0x0
		SetFlag(BelieveInDemonsFlag)
		Text(Ch0BunnyTalkDemons)
		GOTO 0x1
	LABEL 0x0
	Text(Ch0BunnyTalkNoDemons)
	LABEL 0x1
	CenterTextbox(Ch0ChoiceTutorial)
	NoFade
	ENDA

EndingScene:
	CAMERA [0,0]
	Text(Ch0FogBreaks)
	FadeOutMusic
	FAWI 5
	REMOVEPORTRAITS
	BACG WhiteBG
	FAWU 16
	Text(Ch0Surprise)
	RemoveBackgroundSlow
	SetBackgroundSlow(BlackBG)
	
	CenterTextbox(Ch0OldPrinceDied)
	CenterTextbox(Ch0MyDearestFriend)
	FADI 16
	
	DISA YoungTeacher
	DISA YoungPrince
	
	DISA 0x80
	DISA 0x80
	DISA 0x80
	DISA 0x80
	DISA 0x80
	
	DISA 0x80
	DISA 0x80
	DISA 0x80
	DISA 0x80
	DISA 0x80
	
	DISA 0x80
	DISA Ch0Bunny
	DISA Jerry
	DISA 0x81
	DISA 0x82
	DISA 0x84
	
	MNC2 Ch1
	
	NoFade
	ENDA

BleedoutChapterAlwaysEvent:
	ASMC ReviveAndSetPetrify|1
	NoFade
	ENDA

BleedoutChapterTurnEvent:
	CALL BleedoutTurnEvent
	NoFade
	ENDA
	
	
// Chapter Select Menu

Start := 0x1000
CSPg1 := 0x8001
CSPg2 := 0x8002
CSGo := 0x8010
EndPage := 0x8999
GoToNextPage := 0x9000
GoBack := 0x9001

EndMenuSkipStartEvent := 0x9003
EndMenu := 0x9002

GameStartMenuEvent:
	PreventSkipping
	CLEAN
	SetBackground(0x35)
	FADU 16
LABEL Start
	CallMenu(GameStartMenu)
	BEQ 0x0 0xC 0
	SVAL 8 1
	BEQ 0x1 0xC 8
	
	LABEL 0x1
	CallMenu(GSMChapterSelectPg1)
	GOTO CSPg1
	
	LABEL 0x0
	GOTO EndMenu

LABEL CSPg1
// result in slot 0xC
/*
0: Back
1: Ch 1
2: Ch 2
3: Ch 3
4: Ch 4
5: Ch 5
6: Ch 6
7: Next Page
*/
// Slot 2 has chapter number to check
// Slot 8 will have target chapter number

	SADD 5 0xC 0
	SVAL 2 0x0
	BEQ GoBack 5 2
	//CenterTextbox(DebugPauseText)
	SVAL 2 0x1
	BEQ 0x11 5 2
	//CenterTextbox(DebugPauseText)
	SVAL 2 0x2
	BEQ 0x12 5 2
	//CenterTextbox(DebugPauseText)
	SVAL 2 0x3
	BEQ 0x13 5 2
	//CenterTextbox(DebugPauseText)
	SVAL 2 0x4
	BEQ 0x14 5 2
	//CenterTextbox(DebugPauseText)
	SVAL 2 0x5
	BEQ 0x15 5 2
	//CenterTextbox(DebugPauseText)
	SVAL 2 0x6
	BEQ 0x16 5 2
	//CenterTextbox(DebugPauseText)
	SVAL 2 0x7
	BEQ GoToNextPage 5 2

	LABEL GoBack
		//CenterTextbox(DebugPauseText)
		GOTO Start
	
	LABEL 0x11
		SVAL 8 Ch1
		//CenterTextbox(DebugPauseText)
		GOTO EndPage
		
	LABEL 0x12
		SVAL 8 Ch2
		//CenterTextbox(DebugPauseText)
		GOTO EndPage
		
	LABEL 0x13
		SVAL 8 Ch3
		//CenterTextbox(DebugPauseText)
		GOTO EndPage
		
	LABEL 0x14
		SVAL 8 Ch4
		//CenterTextbox(DebugPauseText)
		GOTO EndPage
		
	LABEL 0x15
		SVAL 8 Ch5
		//CenterTextbox(DebugPauseText)
		GOTO EndPage
		
	LABEL 0x16
		SVAL 8 Ch6
		//CenterTextbox(DebugPauseText)
		GOTO EndPage
		
	LABEL GoToNextPage
		//CenterTextbox(DebugPauseText)
		GOTO CSPg2

	LABEL EndPage
		//CenterTextbox(DebugPauseText)
		GOTO CSGo
		
//------------------------	
	LABEL CSPg2
	GOTO Start
	
//------------------------
	LABEL CSGo
	//SVAL 7 0x1
	//SSUB 8 8 7 //increase target chapter number by 0x1, so you can do less-than
	//actually don't need to do this
	
	//CenterTextbox(DebugPauseText)
	SVAL 7 Ch1
	BLT EndMenuSkipStartEvent 8 7
		//CenterTextbox(DebugPauseText)
		MNC2 Ch1
		//GOTO EndMenuSkipStartEvent
	
	//CenterTextbox(DebugPauseText)
	SVAL 7 Ch2
	BLT EndMenuSkipStartEvent 8 7
		//CenterTextbox(DebugPauseText)
		LOAD1 0x1 UnitsCh1
		//CenterTextbox(DebugPauseText)
		SilentGiveItem(HandAxe,Dragon)
		//CenterTextbox(DebugPauseText)
		SilentGiveItem(LongFuseBomb,Brother)
		//CenterTextbox(DebugPauseText)
		MNC2 Ch2
		//GOTO EndMenuSkipStartEvent
	
	//CenterTextbox(DebugPauseText)	
	SVAL 7 Ch3
	CenterTextbox(DebugPauseText)
	BLT EndMenuSkipStartEvent 8 7
		// fill this in later with ch. 2 stuff
		LOAD1 0x1 UnitsCh2
		SilentGiveItem(SteelBow,Hunter)
		//SilentGiveItem(CrystalKnife,HeroChar)
		SilentGiveItem(Butterfly,Teacher)
		CenterTextbox(DebugPauseText)
		AutoLevel(HeroChar, 5)
		AutoLevel(Dragon, 5)
		AutoLevel(Pillow, 5)
		AutoLevel(Pigeon, 5)
		AutoLevel(Brother, 5)
		MNC2 Ch3
		//GOTO EndMenuSkipStartEvent
	
	LABEL EndMenuSkipStartEvent
	//CenterTextbox(DebugPauseText)
	SetFlag(SkipStartEvent)
	LABEL EndMenu
	//CenterTextbox(DebugPauseText)
	FADI 16
	CLEAN
	NoFade
	ENDA
	
HeroGenderFlagTurnEvent:
	UnsetFlag(HeroGenderswapFlag)
	NoFade
	ENDA
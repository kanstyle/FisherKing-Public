	UNIT HeroChar UpstartM 0x40 Level(4,Ally,True)     	[14,9] 0b 0x0 0x0 0x0 [IronBow, Fire, HerosFlair, Restore] [0x0,0x0,0x0,0x0]
	UNIT Dragon Headsman 0x40 Level(4,Ally,True)     	[11,8] 0b 0x0 0x0 0x0 [SteelAxe, SlimAxe, Bomb, Vulnerary] [0x0,0x0,0x0,0x0]
	UNIT Pillow LowVoice 0x40 Level(4,Ally,True)     	[11,8] 0b 0x0 0x0 0x0 [Loneliness, Pain] [0x0,0x0,0x0,0x0]

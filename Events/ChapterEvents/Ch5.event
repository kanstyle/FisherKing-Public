	NoFade
	ENDA

BeginningScene:
	CALL StartEventRoutine

	LOMA 0x30
	LOAD2 0x1 DragonPillowUnits
	MUSC Nighttime
	FADU 4
	STAL 90

	Text(Ch5IntroDragonPillow)
	STAL 60
	MUSCSLOW EnemyAttackID
	LOAD2 0x1 BaronWoundedUnits
	MOVE 3 0x80 [7,8]
	ENUN
	STAL 30
	MOVE 4 0x80 [7,6]
	ENUN
	Highlight(0x80)
	Text(Ch5IntroBaronWounded1)
	STAL 45
	LOAD2 0x1 BaronWoundedCiviliansUnits
	ENUN
	MOVE 3 CivMan [8,8]
	ENUN
	STAL 40
	MOVE 8 Dragon [7,5]
	ENUN
	Text(Ch5IntroBaronWounded2)
	STAL 30
	LOAD2 0x1 TeacherHeroGryphonUnits
	MOVE 8 HeroChar [7,4]
	MOVE 8 Teacher [6,3]
	MOVE 8 Eagle [7,3]
	MOVE 8 Gryphon [8,3]
	ENUN
	STAL 40
	Highlight(HeroChar)
	Text(Ch5IntroBaronWounded3)
	
	FADI 8
	DoAllThree
	LOMA 0x6
	LOAD2 0x1 CivilianUnitsCutscene
	LOAD2 0x1 CivilianUnits
	LOAD2 0x1 MonsterUnitsCutscene
	CAMERA [18,16]
	FADU 8
	STAL 60
	MOVE 3 0xF2 [16,16]
	MOVE 3 0x81 [17,17]
	ENUN
	STAL 30
	Highlight(0xF2)
	Text(Ch5IntroCivilianRunning)
	
	MOVE 8 Beast [17,16]
	ENUN
	StartBattle
	NormalDamage(0x0,30)
	FIGHT_MAP Beast 0xF2 SharpClaw 0x0
	DISA 0xF2
	
	CAMERA [22,6]
	MOVE 5 0x84 [22,7]
	MOVE 5 0x85 [23,7]
	MOVE 5 0x86 [21,7]
	MOVE 5 Ch5Skull [22,8]
	ENUN
	Highlight(Ch5Skull)
	Text(Ch5IntroSkullChildren)
	MOVE 5 0x84 [22,6]
	ENUN
	DISA 0x84
	MOVE 5 0x85 [22,6]
	ENUN
	DISA 0x85
	MOVE 5 0x86 [22,6]
	ENUN
	DISA 0x86
	MOVE 5 Ch5Skull [22,6]
	ENUN
	Highlight(Ch5Skull)
	Text(Ch5IntroSkullChildren2)
	
	CAMERA [2,8]
	//show bunny's mother hiding with her mother and wishing bunny would come home
	CameraCursorLocation(2,8,60)
	SetBackground(HouseBG)
	Text(Ch5IntroBunnyMother)
	FADI 8
	CLEAN
	FADU 8
	
	CAMERA [0,0]
	//player squad arrives
	LOAD2 0x1 PlayerSquadUnits
	ENUN
	STAL 30
	LOAD2 0x1 PlayerSquadUnitsPillow
	UNCM(Pillow,Hide)
	MOVE 65535 Pillow [5,2]
	WARPIN [5,2]
	UNCR(Pillow,Hide)
	ENDWARP
	Highlight(Teacher)
	Text(Ch5IntroPlayerSquad)
	
	FADI 8
	DoAllThree
	LOAD2 0x1 EagleUnits
	LOAD2 0x1 EnemyUnits
	LOAD2 0x1 NPCUnits
	SetFlag(StormSkullTalkFlag)
	GotoPrepScreen
	ENDA
	

EventPointerTable(Ch5EventsID, PointerList)

#define StormBabyTalkFlag 0x7 
#define GaleBabyTalkFlag 0x8
#define StormHeroTalkFlag 0x9 
#define GaleHeroTalkFlag 0x10
#define StormSkullTalkFlag 0x11

PointerList:
	POIN TurnBasedEvents
	POIN CharacterBasedEvents
	POIN LocationBasedEvents
	POIN MiscBasedEvents
	POIN Dunno1 Dunno2 Dunno3 Tutorial
	POIN Traps1 Traps2
	POIN Units1 Units1  //This unit group determines the number and position of deployment slots when there is a prep screen
	POIN $0 $0 $0
	POIN $0 $0 $0
	POIN BeginningScene EndingScene

TurnBasedEvents:
	TurnEventPlayer(0x0,BleedoutChapterTurnEvent,1,255)
	TurnEventPlayer(0x0,HeroGenderFlagTurnEvent,1,255)
	TurnEventPlayer(0x0,StormGaleIntro,1)
	TurnEventPlayer(0x0,Turn1Routine,1)
	TurnEventPlayer(0x0,Turn1Event,1)
	END_MAIN

ALIGN 32
CharacterBasedEvents:
	CharacterEventBothWays(StormBabyTalkFlag,StormBabyTalk,Storm,Baby)
	CharacterEventBothWays(GaleBabyTalkFlag,GaleBabyTalk,Gale,Baby)
	CharacterEventBothWays(StormHeroTalkFlag,StormHeroTalk,Storm,HeroChar)
	CharacterEventBothWays(GaleHeroTalkFlag,GaleHeroTalk,Gale,HeroChar)
	CharacterEventBothWays(StormSkullTalkFlag,StormSkullTalk,Storm,Skull)
	END_MAIN

MiscBasedEvents:
	CauseGameOverIfLordDies
	AFEV BleedoutFlag BleedoutChapterAlwaysEvent 0x0
	END_MAIN

LocationBasedEvents:
	END_MAIN

Dunno1:

	END_MAIN

Dunno2:

	END_MAIN

Dunno3:

	END_MAIN

Tutorial:

	END_MAIN


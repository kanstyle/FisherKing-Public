#define WarpAndDraw(unitGroup1,unitGroup2,unitGroup3,warpX,warpY,draw1X,draw1Y,draw2X,draw2Y) "\
	CAM1 [draw1X,draw1Y]; \
	LOAD2 0x1 unitGroup1; \
	WARPIN [warpX,warpY]; \
	ENDWARP; \
	STAL 40; \
		LOAD2 0x1 unitGroup2; \
		SFX(0x312); \
		Draw(MapDark,draw1X,draw1Y); \
		STAL 20; \
		LOAD2 0x1 unitGroup3; \
		SFX(0x312); \
		Draw(MapDark,draw2X,draw2Y); \
	STAL 30"
	
NEStairsReinforcementEvent:
	LoadReinforcements(NEStairsReinforcementUnits)
	NoFade
	ENDA

EndingScene:
	WarpAndDraw(JabberwockLeftUnits, JabberwockLeftUnits1, JabberwockLeftUnits2,\
	3, 18,\
	2, 17,\
	4, 19)
	
	WarpAndDraw(JabberwockCenterUnits, JabberwockCenterUnits1, JabberwockCenterUnits2,\
	12, 16,\
	11, 15,\
	13, 15)

	WarpAndDraw(JabberwockRightUnits, JabberwockRightUnits1, JabberwockRightUnits2,\
	19, 17,\
	18, 18,\
	20, 16)
	
	//text: eagle/teacher/hero reacting to the jabberwocks appearing. they're really big
	//jabberwocks spawn more monsters
	//text: oh shit
	
	FADI 8
	CAM1 [7,0] //camera on central building
	DoAllThree
	LOAD2 0x1 CivilianUnits
	LOAD2 0x1 PlayerSquadUnitsEnd
	FADU 8
	Highlight(11,1)
	Text(Ch5CiviliansScared)
	
	//jabberwocks warp to building entrances
	
	WarpAndDraw(JabberwockLeftUnits02, JabberwockLeftUnits12, JabberwockLeftUnits22,\
	6, 3,\
	5, 2,\
	5, 4)
	
	WarpAndDraw(JabberwockCenterUnits02, JabberwockCenterUnits12, JabberwockCenterUnits22,\
	13, 8,\
	12, 9,\
	14, 9)

	WarpAndDraw(JabberwockRightUnits02, JabberwockRightUnits12, JabberwockRightUnits22,\
	17, 3,\
	18, 2,\
	18, 4)
	
	CAM1 [12,4]
	STAL 30
	Highlight(Ch5Eagle)
	Text(Ch5DevilsComing)
	
	CAM1 [12,4]
	STAL 60
	LOAD2 0x1 DevilUnits
	UNCM(Devil,Hide)
	MOVE 65535 Devil [12,4]
	WARPIN [12,4]
	UNCR(Devil,Hide)
	ENDWARP
	STAL 60
	Highlight(Devil)
	Text(Ch5DevilIntro)
	CenterTextbox(Ch5DevilDescription)
	Text(Ch5DevilTargeting)
	STAL 30
	
	//mome rath event battle
	StartBattle
	CriticalHit(0x0,90)
	FIGHT Devil JabberwockBlocker DevilMagic 0x0
	DISA JabberwockBlocker
	
	STAL 30
	Text(Ch5DevilMissed)
	Highlight(Dragon)
	Text(Ch5DragonEagleArgue)
	STAL 60
	SFX(0xB4) //play warp in sound
	STAL 30
	HighlightTile(11,0)
	Text(Ch5JabberwockBack)
	Highlight(Dragon)
	Text(Ch5DragonEagleArgue2)
	
	FADI 4
	DoAllThree
	DISA Ch5Eagle
	CALL EndEventRoutine
	MNC2 Ch5d
	NoFade
	ENDA
	

BunnyMotherVisit:
	SetBackground(HouseBG)
	CHECK_ACTIVE
	SVAL 0x1 Bunny
	BNE 0x0 0xC 0x1
		Text(Ch5BunnyMotherVisit)
		GiveItemWithDurability(SkillScroll,52,0xFFFF)
		GiveItem(Razorbeak,0xFFFF)
		//get both items
		RemoveBackground
		FADU 16
	GOTO 0x2
	LABEL 0x0
		Text(Ch5BunnyMotherGenericVisit)
		CallMenu(Ch5BunnyMenu)
		BNE 0x1 0xC 0x0
			RemoveBackground 
			FADU 16
			GiveItemWithDurability(SkillScroll,52,0xFFFF)
			GOTO 0x2
		LABEL 0x1
			RemoveBackground
			FADU 16
			GiveItem(Razorbeak,0xFFFF)
			GOTO 0x2
	LABEL 0x2
	NoFade
	ENDA
	

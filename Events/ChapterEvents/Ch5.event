LargeReinforcementEvent:
	MUSC EnemyAttackID
	STAL 30
	CameraCursor(HeroChar)
	Text(Ch5LargeReinforcementText1)
	CallMenu(Ch5LargeReinforcementMenu) //menu where you pick a side to spawn reinforcements on
	BNE 0x0 0xC 0x0
		LoadReinforcements(SEReinforcementUnits)
		LoadReinforcements(CenterReinforcementUnits)
		LoadReinforcements(SWReinforcementLargeUnits)
		GOTO 0x3
		LABEL 0x0
	SVAL 0x8 0x1
	BNE 0x1 0xC 0x8
		LoadReinforcements(SWReinforcementUnits)
		LoadReinforcements(SEReinforcementUnits)
		LoadReinforcements(CenterReinforcementLargeUnits)
		GOTO 0x3
		LABEL 0x1
	SVAL 0x8 0x2
	BNE 0x2 0xC 0x8
		LoadReinforcements(SWReinforcementUnits)
		LoadReinforcements(CenterReinforcementUnits)
		LoadReinforcements(SEReinforcementLargeUnits)
		GOTO 0x3
		LABEL 0x2
	LABEL 0x3
	STAL 60
	Text(Ch5LargeReinforcementText2)
	NoFade
	ENDA
	
LargeReinforcementEvent2:
	MUSC EnemyAttackID
	STAL 30
	CameraCursor(HeroChar)
	Text(Ch5LargeReinforcement2Text1)
	CLEAN
	CallMenu(Ch5LargeReinforcementMenu) //menu where you pick a side to spawn reinforcements on
	BNE 0x0 0xC 0x0
		LoadReinforcements(SEReinforcementLargeUnits)
		LoadReinforcements(CenterReinforcementLargeUnits)
		GOTO 0x3
		LABEL 0x0
	SVAL 0x8 0x1
	BNE 0x1 0xC 0x8
		LoadReinforcements(SEReinforcementLargeUnits)
		LoadReinforcements(SWReinforcementLargeUnits)
		GOTO 0x3
		LABEL 0x1
	SVAL 0x8 0x2
	BNE 0x2 0xC 0x8
		LoadReinforcements(CenterReinforcementLargeUnits)
		LoadReinforcements(SWReinforcementLargeUnits)
		GOTO 0x3
		LABEL 0x2
	LABEL 0x3
	Text(Ch5LargeReinforcement2Text2)
	NoFade
	ENDA


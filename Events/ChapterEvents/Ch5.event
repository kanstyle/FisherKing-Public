EventPointerTable(Ch5EventsID, PointerList)

#define StormBabyTalkFlag 0x7 
#define GaleBabyTalkFlag 0x8
#define StormHeroTalkFlag 0x9 
#define GaleHeroTalkFlag 0x10
#define StormSkullTalkFlag 0x11
#define HeroSkullTalkFlag 0x12
#define BunnyVillageFlag 0x13
#define SkullVillageFlag 0x14

#define JBLeft 0x90
#define JBCenter 0x91
#define JBRight 0x92

#define JBLeft1 0x93
#define JBLeft2 0x94
#define JBCenter1 0x95
#define JBCenter2 0x96
#define JBRight1 0x97
#define JBRight2 0x98


PointerList:
	POIN TurnBasedEvents
	POIN CharacterBasedEvents
	POIN LocationBasedEvents
	POIN MiscBasedEvents
	POIN Dunno1 Dunno2 Dunno3 Tutorial
	POIN Traps1 Traps2
	POIN Units1 Units1  //This unit group determines the number and position of deployment slots when there is a prep screen
	POIN $0 $0 $0
	POIN $0 $0 $0
	POIN BeginningScene EndingScene

TurnBasedEvents:
	TurnEventEnemy(0x0,BleedoutChapterTurnEvent,1,255)
	TurnEventPlayer(0x0,HeroGenderFlagTurnEvent,1,255)
	TurnEventPlayer(0x0,StormGaleIntro,1)
	TurnEventPlayer(0x0,Turn1Routine,1)
	TurnEventPlayer(0x0,Turn1Event,1)
	//TurnEventPlayer(0x0,Turn2Reinforcements,2)
	TurnEventPlayer(0x0,LargeReinforcementEvent,3)
	TurnEventPlayer(0x0,Turn2Reinforcements,5)
	TurnEventPlayer(0x0,SETarvosReinforcements,4)
	TurnEventPlayer(0x0,SETarvosReinforcements,5)
	//TurnEventPlayer(0x0,WReinforcements,4)
	TurnEventPlayer(0x0,WReinforcements,5)
	TurnEventPlayer(0x0,LargeReinforcementEvent2,6)
	TurnEventPlayer(0x0,NEStairsReinforcementEvent,7)
	TurnEventPlayer(0x0,Turn2Reinforcements,7)
	TurnEventPlayer(0x0,WReinforcements,7)
	TurnEventPlayer(0x0,SETarvosReinforcements,7)
	TurnEventPlayer(0x0,EndingScene,9)
	END_MAIN

ALIGN 32
CharacterBasedEvents:
	CharacterEventBothWays(StormBabyTalkFlag,StormBabyTalk,Storm,Baby)
	CharacterEventBothWays(GaleBabyTalkFlag,GaleBabyTalk,Gale,Baby)
	CharacterEventBothWays(StormHeroTalkFlag,StormHeroTalk,Storm,HeroChar)
	CharacterEventBothWays(GaleHeroTalkFlag,GaleHeroTalk,Gale,HeroChar)
	CharacterEventBothWays(StormSkullTalkFlag,StormSkullTalk,Storm,Ch5Skull)
	CharacterEventBothWays(HeroSkullTalkFlag,SkullTalk,HeroChar,Ch5Skull)
	//CharacterEventBothWays(HeroSkullTalkFlag,LargeReinforcementEvent,HeroChar,Ch5Skull)
	END_MAIN

MiscBasedEvents:
	CauseGameOverIfLordDies
	AFEV BleedoutFlag BleedoutChapterAlwaysEvent 0x0
	AREA 0x0 DefendGameOver [8,0] [15,5]
	END_MAIN

LocationBasedEvents:
	Village(BunnyVillageFlag,BunnyMotherVisit,2,8)
	Village(SkullVillageFlag,SkullVisit,22,6)
	Door(21,2)
	Door(12,11)
	Door(13,11)
	Chest(Restore,10,12)
	Armory(Ch5Armory,2,1)
	Vendor(Ch5Vendor,18,1)
	END_MAIN

Dunno1:

	END_MAIN

Dunno2:

	END_MAIN

Dunno3:

	END_MAIN

Tutorial:

	END_MAIN


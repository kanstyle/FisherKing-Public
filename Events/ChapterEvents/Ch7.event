WiseTalk:
	FlagIsSet(HelpedWiseFlag, 0x0)
		Text(Ch7WiseTalkHelpedText)
		GiveItem(Butterfly,0xFFFF)
		GOTO 0x1
	LABEL 0x0
	Text(Ch7WiseTalkText)
	LABEL 0x1
	GiveItem(Loneliness,0xFFFF)
	NoFade
	ENDA
	
Ch7EVillageEvent:
	FADI 16
	SetBackground(HouseBG)
	Text(Ch7EVillageText)
	GiveItem(AkashicBow,0xFFFF)
	NoFade
	ENDA
	
Ch7MVillageEvent:
	FlagNotSet(Ch7MVillageWaitingFlag, 0x0)
		// ---- First visit: merchant offers the Silver Lance ----
		FADI 16
		SetBackground(HouseBG)
		Text(Ch7MVillageIntroText)
		CallMenu(Ch7MVillageMenu1)
		BNE 0x1 0xC 0x0
			// Option 0: buy now for 3000 gold
			CHECK_MONEY
			SVAL 1 3000
			BLT 0x2 0xC 0x1
				SilentSubGold(3000)
				GiveItem(SilverLance,0xFFFF)
				Text(Ch7MVillageBoughtText)
				GOTO 0x4
		LABEL 0x1
			// Option 1: wait two turns for a better price
			CenterTextbox(Ch7MVillageReminder)
			COUNTER_SET 0 2
			SetFlag(Ch7MVillageWaitingFlag)
			UnsetFlag(Ch7MVillageWindowFlag)
			UnsetFlag(Ch7MVillageWindowPassedFlag)
			UnsetFlag(Ch7MVillageFlag)
			GOTO 0x4
		LABEL 0x2
			// Not enough gold
			Text(Ch7MVillageNoGoldText)
			UnsetFlag(Ch7MVillageFlag)
			GOTO 0x4

	LABEL 0x0
	// ---- Revisit while waiting ----
	FlagIsSet(Ch7MVillageWindowFlag, 0x3)
		// Came back on exactly the right turn
		FlagIsSet(Ch7MVillageWaitFreeFlag, 0x6)
			// Third visit: player committed to waiting for free
			FADI 16
			SetBackground(HouseBG)
			Text(Ch7MVillageFreeText)
			GiveItem(SilverLance,0xFFFF)
			SetFlag(Ch7MVillageFlag)
			UnsetFlag(Ch7MVillageWaitingFlag)
			UnsetFlag(Ch7MVillageWindowFlag)
			UnsetFlag(Ch7MVillageWindowPassedFlag)
			UnsetFlag(Ch7MVillageWaitFreeFlag)
			GOTO 0x4
		LABEL 0x6
		// Second visit: offer buy 1500 or wait for free
		FADI 16
		SetBackground(HouseBG)
		Text(Ch7MVillageReturnText)
		/*RemoveBackground
		FADU 16*/
		CallMenu(Ch7MVillageMenu2)
		BNE 0x5 0xC 0x0
			// Option 0: buy now for 1500 gold
			CHECK_MONEY
			SVAL 1 1500
			BLT 0x2 0xC 0x1
				SilentSubGold(1500)
				GiveItem(SilverLance,0xFFFF)
				Text(Ch7MVillageBought1500Text)
				SetFlag(Ch7MVillageFlag)
				UnsetFlag(Ch7MVillageWaitingFlag)
				UnsetFlag(Ch7MVillageWindowFlag)
				UnsetFlag(Ch7MVillageWindowPassedFlag)
				GOTO 0x4
	LABEL 0x5
		// Option 1: wait two more turns for it to be free
		COUNTER_SET 0 2
		SetFlag(Ch7MVillageWaitFreeFlag)
		UnsetFlag(Ch7MVillageWindowFlag)
		UnsetFlag(Ch7MVillageWindowPassedFlag)
		UnsetFlag(Ch7MVillageFlag)
		GOTO 0x4

	LABEL 0x3
	// Came back on the wrong turn - deal's off
	FADI 16
	SetBackground(HouseBG)
	Text(Ch7MVillageWrongTurnText)
	/*RemoveBackground
	FADU 16*/
	SetFlag(Ch7MVillageFlag)
	UnsetFlag(Ch7MVillageWaitingFlag)
	UnsetFlag(Ch7MVillageWindowFlag)
	UnsetFlag(Ch7MVillageWindowPassedFlag)
	UnsetFlag(Ch7MVillageWaitFreeFlag)

	LABEL 0x4
	RemoveBackground
	FADU 16
	NoFade
	ENDA

Ch7MVillageTurnCheck:
	FlagIsSet(Ch7MVillageWaitingFlag, 0x0)
	FlagNotSet(Ch7MVillageWindowPassedFlag, 0x0)
	FlagIsSet(Ch7MVillageWindowFlag, 0x1)
		// The window was open and went unused - close it for good
		UnsetFlag(Ch7MVillageWindowFlag)
		SetFlag(Ch7MVillageWindowPassedFlag)
		GOTO 0x0
	LABEL 0x1
		// Count down to the 2-turn mark, then open the window
		COUNTER_DEC 0
		COUNTER_CHECK 0
		BNE 0x0 0xC 0x0
		SetFlag(Ch7MVillageWindowFlag)
	LABEL 0x0
	NoFade
	ENDA

Ch7WVillageEvent:
	FADI 16
	SetBackground(HouseBG)
	Text(Ch7WVillageText)
	RemoveBackground
	FADU 16
	CallMenu(Ch7WVillageMenu)
	BNE 0x0 0xC 0x0
		GiveItem(KillerBow,0xFFFF)
		GOTO 0x1
	LABEL 0x0
	GiveItemWithDurability(SkillScroll,RunicID,0xFFFF)
	LABEL 0x1
	NoFade
	ENDA
	
ALIGN 4

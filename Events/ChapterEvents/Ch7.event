CheckLowMageSurvival:
	CHECK_EXISTS Ch7LowMage
	BTrue(0x0)
		CHECK_EXISTS Ch7Wise
		BTrue(0x0)
		GameOver
	LABEL 0x0
	NoFade
	ENDA
	
CheckBossSurvival:
	CHECK_EXISTS Captain
	BTrue(0x0)
		CHECK_EXISTS Recruiter
		BTrue(0x0)
		GameOver
	LABEL 0x0
	NoFade
	ENDA


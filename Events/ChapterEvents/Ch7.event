	SHORT SteelSword
	SHORT SteelLance
	SHORT SteelAxe
	SHORT SlimLance
	SHORT SlimAxe
	SHORT Javelin
	SHORT HandAxe
	SHORT Hammer
	SHORT 0
	SHORT 0
	
ALIGN 4

BeginningScene: 
	MUSC FFTAnxiety
	CALL StartEventRoutine
	SetBackground(Forest)
	BROWNBOXTEXT Ch7OutskirtsBrownBox [8,8]
	Text(Ch7IntroDiscussion)
	FADI 4
	MUSCSLOW NoticeOfDeathID
	CLEAN
	CAM1 [11,15]
	LOAD2 0x1 CaptainSquad1
	LOAD2 0x1 CaptainSquad2
	LOAD2 0x1 CaptainSquad3
	LOAD2 0x1 CutsceneSoldierUnits
	LOAD2 0x1 CivilianUnits
	FADU 4
	STAL 60
	Highlight(11,13)
	Text(Ch7SoldierIntro)
	STAL 60
	LOAD2 0x2 CutsceneWiseUnits
	Highlight(Ch7Wise)
	Text(Ch7SoldierIntro2)
	
	MOVE 5 0x81 [9,15]
	MOVE 5 0x82 [11,15]
	MOVE 5 0x83 [13,15]
	ENUN
	DISA 0x81
	DISA 0x82
	DISA 0x83
	STAL 60
	MOVE 5 Ch7Wise [11,14]
	ENUN
	STAL 30
	Highlight(Ch7Wise)
	Text(Ch7WiseIntro)
	STAL 30
	
	CAM1 [21,0]
	STAL 30
	CAM1 [3,0]
	Highlight(Recruiter)
	Text(RecruiterIntro)
	STAL 45
	LOAD2 0x1 CutsceneIntroWardenUnits
	STAL 30
	MOVE 5 0x82 [4,1]
	ENUN
	Highlight(0x82)
	Text(RecruiterWarden)
	MOVE 5 0x82 [4,0]
	ENUN
	DISA 0x82
	STAL 60
	
	CAM1 [26,9]
	STAL 45
	LOAD2 0x1 CutscenePlayerUnits
	STAL 30
	WARPIN [26,9]
	MOVE 65535 Pillow [26,9]
	ENDWARP
	Highlight(HeroChar)
	//Text(Ch7HeroIntro)
	
	FADI 4
	DoAllThree
	LOAD1 0x1 EnemyUnits
	LOAD1 0x1 NPCUnits
	LOAD1 0x1 CaptainSquad1
	LOAD1 0x1 CaptainSquad2
	LOAD1 0x1 CaptainSquad3
	
	GotoPrepScreen
	ENDA

EndingScene:
	FADI 4
	CALL EndEventRoutine
	DoAllThree
	CAM1 [4,8]
	LOAD2 0x1 PlayerUnitsEndCutscene
	LOAD2 0x1 CutsceneIntroWardenUnits
	SetBackground(Plain)
	//Text() //talking to Wise
	FADI 8
	CLEAN
	FADU 8
	
	STAL 60
	MOVE 5 0x82 [4,6]
	ENUN
	STAL 30
	MUSCMID NoticeOfDeathID
	Highlight(0x82)
	Text(Ch7EndWardenAppears)
	STAL 45
	//Warden summons soldiers
	WARPIN [3,5]
	LOAD2 0x1 WardenGuardsEndCutscene1
	ENDWARP
	STAL 45
	WARPIN [4,4]
	LOAD2 0x1 WardenGuardsEndCutscene2
	ENDWARP
	STAL 45
	WARPIN [5,5]
	LOAD2 0x1 WardenGuardsEndCutscene3
	ENDWARP
	STAL 45
	WARPIN [3,4]
	LOAD2 0x1 WardenGuardsEndCutscene4
	ENDWARP
	STAL 45
	WARPIN [5,4]
	LOAD2 0x1 WardenGuardsEndCutscene5
	ENDWARP
	STAL 45
	Highlight(Dragon)
	FADI 8
	SetBackground(Plain)
	Text(Ch7EndWardenAppears2) //Dragon wants to attack Warden
	FADI 4
	STAL 90
	MUSCSLOW 0x777F
	STAL 60
	SetBackgroundSlow(Heart)
	CenterTextbox(Ch7EndPillowNarration)
	STAL 60
	FADI 4
	CLEAN
	STAL 60
	SetBackground(BlackBG)
	CenterTextbox(Ch7EndDragonInjuredNarration)
	FADI 4
	CLEAN
		
	MNC2 Ch0
	NoFade
	ENDA
	

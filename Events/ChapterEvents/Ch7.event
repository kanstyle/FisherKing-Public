Traps1:
	ENDTRAP
	ALIGN 4

Traps2:
	ENDTRAP
	ALIGN 4
	
CheckLowMageSurvival:
	CHECK_EXISTS Ch7LowMage
	BTrue(0x0)
		CHECK_EXISTS Ch7Wise
		BTrue(0x0)
		GameOver
	LABEL 0x0
	NoFade
	ENDA
	
CheckBossSurvival:
	CHECK_EXISTS Captain
	BTrue(0x0)
		/*CHECK_EXISTS BossName
		BTrue(0x0)*/
		GameOver
	LABEL 0x0
	NoFade
	ENDA

CaptainSquad2Charge:
	CAM1 [13,1]
	STAL 30
	Highlight(13,1)
	//Text(Placeholder)
	ChangeAICharge(13,1)
	ChangeAICharge(14,2)
	ChangeAICharge(12,2)
	ChangeAICharge(13,0)
	NoFade
	ENDA
	
CaptainSquad3Charge:
	CAM1 [3,1]
	STAL 30
	Highlight(3,1)
	//Text(Placeholder)
	ChangeAICharge(3,1)
	ChangeAICharge(2,2)
	ChangeAICharge(4,2)
	ChangeAICharge(3,0)
	NoFade
	ENDA

BeginningScene:
	CALL StartEventRoutine
	
	DoAllThree
	LOAD1 0x1 EnemyUnits
	LOAD1 0x1 NPCUnits
	LOAD1 0x1 CaptainSquad1
	LOAD1 0x1 CaptainSquad2
	LOAD1 0x1 CaptainSquad3
	
	
	GotoPrepScreen
	ENDA

EndingScene:
	CALL EndEventRoutine
		
	MNC2 Ch0
	NoFade
	ENDA
	
ALIGN 4

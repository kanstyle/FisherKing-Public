	MNC2 Ch2
	NoFade
	ENDA

BleedoutChapterAlwaysEvent:
	ASMC ReviveAndSetPetrify|1
	NoFade
	ENDA

BleedoutChapterTurnEvent:
	CALL BleedoutTurnEvent
	NoFade
	ENDA
	
HeroGenderFlagTurnEvent:
	UnsetFlag(HeroGenderswapFlag)
	NoFade
	ENDA
	
Ch1Village1Event:
	FADI 16
	SetBackground(HouseBG)
	Text(Ch1Village1Text)
	RemoveBackground
	FADU 16
	CallMenu(Ch1Village1Menu)
	BEQ 0x0 0xC 0x0
		GiveItem(HandAxe,0xFFFF)
		GOTO 0x1
	LABEL 0x0
	GiveItem(Javelin,0xFFFF)
	LABEL 0x1
	NoFade
	ENDA
	
Ch1Village2Event:
	FADI 16
	SetBackground(HouseBG)
	IfActiveUnitIs(Brother,0x0)
		CenterTextbox(Ch1Village2TextBrother)
		CallMenu(Ch1Village2Menu)
			BNE 0x1 0xC 0x0
			CenterTextbox(Ch1Village2BombText)
			RemoveBackground
			FADU 16
			GiveItem(LongFuseBomb,0xFFFF)
			GOTO 0x2
		LABEL 0x1
			CenterTextbox(Ch1Village2LiquorText)
			RemoveBackground
			FADU 16
			GiveItem(Moonshine,0xFFFF)
			GOTO 0x2
	LABEL 0x0
	CenterTextbox(Ch1Village2Text)
	RemoveBackground
	FADU 16
	GiveItem(LongFuseBomb,0xFFFF)
	LABEL 0x2
	NoFade
	ENDA
	
//Ch1Village3Event:
	//ENDA
	
Ch1BrotherTeacherTalk:
	Text(Ch1BrotherTeacherTalkText)
	CUSA Brother
	NoFade
	ENDA
	
Ch1BrotherHeroTalk:
	IfHeroMale(0x0)
		Text(Ch1BrotherHeroMTalkText)
		GOTO 0x1
	LABEL 0x0
	Text(Ch1BrotherHeroFTalkText)
	LABEL 0x1
	CUSA Brother
	NoFade
	ENDA
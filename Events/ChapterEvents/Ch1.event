Traps1:
	ENDTRAP
	ALIGN 4

Traps2:
	ENDTRAP
	ALIGN 4

BeginningScene:
	SetFlag(BleedoutFlag)
	
	SetBackground(BlackBG)
	CenterTextbox(Ch1OpeningNarration)
	STAL 30
	CenterTextbox(Ch1OpeningNarration2)
	RemoveBackground
	
	SetBackgroundSlow(Outside_Village_Evening)
	Music(FF5_Nostalgia)
	CenterTextbox(Ch1VillageNarration)
	RemoveBackground
	FadeOutMusic
	
	SetBackgroundSlow(Inn)
	Music(PubID)
	Text(Ch1TeacherTavern)
	CenterTextbox(Ch1HeroIntro)
	Text(Ch1HeroIntroDialogue)
	CenterTextbox(Ch1DragonIntro)
	Text(Ch1DragonIntroDialogue)
	CenterTextbox(Ch1PillowIntro)
	Text(Ch1PillowIntroDialogue)
	FadeOutMusic
	RemoveBackgroundSlow
	
	LOAD1 0x1 EnemyUnits
	ENUN
	Music(FFTAnxiety)
	FADU 6
	Highlight(Skull)
	Text(Ch1SkullIntro)
	SingleUnitMove(Pigeon, 8, 0, 1)
	DISA Pigeon
	Text(Ch1SkullIntro2)
	
	Music(HarvestDance)
	LOAD1 0x1 UnitsPillow
	UNCM(Pillow,Hide)
	LOAD1 0x1 Units1
	ENUN
	STAL 30
	WARPIN [11,8]
	UNCR(Pillow,Hide)
	ENDWARP
	STAL 30
	Highlight(Teacher)
	CenterTextbox(Ch1TeacherArrivesNarration)
	Highlight(HeroChar)
	Text(Ch1HeroTeacher)
	
	NoFade
	ENDA

EndingScene:
	FADI 5
	DoAllThree
	LOAD2 0x1 EndEventUnits
	ENUN
	FADU 5
	
	STAL 60
	Highlight(HeroChar)
	SetBackground(Outside_Village_Day)
	Text(Ch1EndEventText1)
	RemoveBackground
	FADU 16
	MOVE 10 Skull [10,2]
	ENUN
	CenterTextbox(Ch1EndEventText2)
	Text(Ch1EndEventText3)
	CenterTextbox(Ch1EndEventText4)
	MOVE 20 Skull [9,2]; ENUN
	Text(Ch1EndEventText5)
	MOVE 10 Skull [0,2]; ENUN
	DISA Skull
	Highlight(Dragon)
	SetBackground(Outside_Village_Day)
	Text(Ch1EndEventText6)
	RemoveBackgroundSlow
	

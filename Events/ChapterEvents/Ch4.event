EndingScene:
	CALL EndEventRoutine
	MNC2 Ch0
	NoFade
	ENDA
	
Turn1Events:
	FlagIsSet(ThiefDealFlag, 0x0)
		CALL ThievesEvent
	LABEL 0x0
	NoFade
	ENDA
	
BackReinforcementSWEvent:
	SpawnReinforcements(BackReinforcementSWUnits)
	NoFade
	ENDA
	
BackReinforcementNWEvent:
	SpawnReinforcements(BackReinforcementNWUnits)
	NoFade
	ENDA
	
BackReinforcementNEEvent:
	SpawnReinforcements(BackReinforcementNEUnits)
	NoFade
	ENDA
	
/*	
EscapeCheckEvent: //THIS CODE WORKS BUT NOT FOR GREEN UNITS BECAUSE THEY DON'T ACTUALLY GET THE ESCAPED STATUS
	GetUnitStatus(Ch4NPCMan,State) //put unit's state bitfield in memory slot C
	//CenterTextbox(DebugPenis)
	//SVAL 0xC 0x10000
	SVAL 1 Escaped //put 0x10000 in memory slot 1
	SAND 0xC 1 0xC //AND operation on slots 1 and C and put the result in slot C. this checks whether the Escaped bit (0x10000) is on
	BNE 0x1 0xC 1 //if slot 1 does not equal slot C, jump to LABEL 0x1
		GetUnitStatus(Ch4NPCWoman,State) //get if unit has escaped status. if both do, end the map
		//CenterTextbox(DebugPenis)
		//SVAL 0xC 0x10000
		SVAL 1 Escaped
		SAND 0xC 1 0xC
		BNE 0x1 0xC 1
			CALL EndingScene
	LABEL 0x1
	NoFade
	ENDA
	*/
	
EscapeCheckEvent:
	CHECK_EXISTS Ch4NPCMan
	//CenterTextbox(DebugPenis)
	SVAL 1 0x1
	BEQ 0x1 0xC 1 //if C equals 0 then
		CHECK_EXISTS Ch4NPCWoman
		//CenterTextbox(DebugPenis)
		SVAL 1 0x1
		BEQ 0x1 0xC 1 //if C equals 0 then
			CALL EndingScene
	LABEL 0x1
	NoFade
	ENDA
	
HeroSwanEvent:
	CAMERA [4,0]
	STAL 30
	REVEAL HeroChar
	LOAD1 0x1 SwanUnits
	ENUN
	Highlight(HeroChar)
	NoFade
	ENDA
	
Ch4NPCTalkMEvent:
	PreventSkipping
	Text(Ch4NPCTalkM)
	CallMenu(Ch4NPCTalkMenu)
		BNE 0x6 0xC 0x0
		Text(Ch4NPCTalkMMove)
		SetAI(Ch4NPCMan,0x0,0xC,0x4,0x0) //move to escape point
		GOTO 0x5
	LABEL 0x6
		AllowSkipping
		Text(Ch4NPCTalkMWait)
		SetAI(Ch4NPCMan,0x0,0x3,0x4,0x20) //don't move at all
		GOTO 0x5
	LABEL 0x5
	NoFade
	ENDA
	
Ch4NPCTalkFEvent:
	PreventSkipping
	Text(Ch4NPCTalkF)
	CallMenu(Ch4NPCTalkMenu)
		BNE 0x6 0xC 0x0
		Text(Ch4NPCTalkFMove)
		SetAI(Ch4NPCWoman,0x0,0xC,0x4,0x0) //move to escape point
		GOTO 0x5
	LABEL 0x6
		AllowSkipping
		Text(Ch4NPCTalkFWait)
		SetAI(Ch4NPCWoman,0x0,0x3,0x4,0x20) //don't move at all
		GOTO 0x5
	LABEL 0x5
	NoFade
	ENDA
	
ThievesEvent:
	CAMERA [12,0]
	CameraCursorLocation(12,0,60)
	STAL 30
	SoundEffect(0xF4) //bolting static
	STAL 45
	FAWI 16
	SoundEffect(0xF8) //elfire hitting
	TILECHANGE 0x0
	TILECHANGE 0x5
	TILECHANGE 0x6
	STAL 15
	FAWU 16
	SoundEffect(0xAF) //destroyed wall
	STAL 45
	
	LOAD1 0x2 ThiefUnits
	ENUN
	CameraCursorLocation(13,1,60)
	Text(Ch4ThiefDialogue1)
	MOVE 5 ThiefUnit [13,3]
	STAL 30
	SoundEffect(DoorEffect)
	TILECHANGE 0x3
	STAL 30
	//NOTIFY Ch4ItemStolen ItemStolen 0x0
	GiveItem(BraveSword,ThiefUnit)
	Text(Ch4ThiefDialogue2)
	
	LOAD2 0x1 ThiefEnemy
	ENUN
	StartBattle
	NormalDamage(0x0,30)
	FIGHT_MAP 0xAE ThiefUnit EvilEye 0x0
	DISA ThiefUnit
	
	MOVE 8 0xAE [13,0]
	ENUN
	DISA 0xAE
	NoFade
	ENDA

BleedoutChapterAlwaysEvent:
	ASMC ReviveAndSetPetrify|1
	NoFade
	ENDA

BleedoutChapterTurnEvent:
	CALL BleedoutTurnEvent
	NoFade
	ENDA

HeroGenderFlagTurnEvent:
	UnsetFlag(HeroGenderswapFlag)
	NoFade
	ENDA
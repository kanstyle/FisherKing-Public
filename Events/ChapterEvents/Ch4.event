EventPointerTable(Ch4EventsID, PointerList)

#define ThiefUnit 0xF0

PointerList:
	POIN TurnBasedEvents
	POIN CharacterBasedEvents
	POIN LocationBasedEvents
	POIN MiscBasedEvents
	POIN Dunno1 Dunno2 Dunno3 Tutorial
	POIN Traps1 Traps2
	POIN Units1 Units1  //This unit group determines the number and position of deployment slots when there is a prep screen
	POIN $0 $0 $0
	POIN $0 $0 $0
	POIN BeginningScene EndingScene

TurnBasedEvents:
	TurnEventPlayer(0x0,BleedoutChapterTurnEvent,1,255)
	TurnEventPlayer(0x0,HeroGenderFlagTurnEvent,1,255)
	TurnEventPlayer(0x0,Turn1Events,1)
	TurnEventPlayer(0x0,HeroSwanEvent,2)
	TurnEventPlayer(0x0,BackReinforcementSWEvent,4,4)
	TurnEventPlayer(0x0,BackReinforcementNWEvent,4,4)
	TurnEventPlayer(0x0,BackReinforcementNEEvent,10,2)
	END_MAIN

ALIGN 32
CharacterBasedEvents:
	CharacterEventBothWays(0x0,Ch4NPCTalkMEvent,0x0,Ch4NPCMan)
	CharacterEventBothWays(0x0,Ch4NPCTalkFEvent,0x0,Ch4NPCWoman)
	END_MAIN

MiscBasedEvents:
	CauseGameOverIfLordDies
	AFEV BleedoutFlag BleedoutChapterAlwaysEvent 0x0
	AFEV 0x0 EscapeCheckEvent 0x0
	END_MAIN

LocationBasedEvents:
	Chest(Speedwings,11,14)
	Chest(Rapier,12,3)
	//DurabilityChest(SkillScroll,PillowsBiggestFanID,12,3)
	Door(10,11)
	Door(11,11)
	Door(13,13)
	END_MAIN


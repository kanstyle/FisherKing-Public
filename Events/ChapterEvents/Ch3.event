EventPointerTable(Ch3EventsID, PointerList)

#define Ch3WiseTalkFlag 0x7
#define Ch3Village1Flag 0x8
#define Ch3Village2Flag 0x9
#define Ch3WomanTalkFlag 0xA

PointerList:
	POIN TurnBasedEvents
	POIN CharacterBasedEvents
	POIN LocationBasedEvents
	POIN MiscBasedEvents
	POIN Dunno1 Dunno2 Dunno3 Tutorial
	POIN Traps1 Traps2
	POIN Units1 Units1  //This unit group determines the number and position of deployment slots when there is a prep screen
	POIN $0 $0 $0
	POIN $0 $0 $0
	POIN BeginningScene EndingScene

TurnBasedEvents:
	TurnEventPlayer(0x0,BleedoutChapterTurnEvent,1,255)
	TurnEventPlayer(0x0,HeroGenderFlagTurnEvent,1,255)
	
	TurnEventPlayer(0x0,ArenaTurnEvent,1,255)
	TurnEventPlayer(0x0,Turn1BabyIntro,1,1)
	TurnEventPlayer(0x0,ArenaWave1Intro,1,1)
	END_MAIN

ALIGN 32
CharacterBasedEvents:
	CharacterEventBothWays(Ch3WiseTalkFlag,Ch3PillowWiseTalk,Pillow,Wise)
	CharacterEventBothWays(Ch3WomanTalkFlag,Ch3WomanTalkEvent,Teacher,Civilian)
	END_MAIN

MiscBasedEvents:
	CauseGameOverIfLordDies
	DefeatBoss
	AFEV BleedoutFlag BleedoutChapterAlwaysEvent 0x0
	END_MAIN

LocationBasedEvents:
	Village(Ch3Village1Flag,Ch3Village1Event,4,20)
	Village(Ch3Village2Flag,Ch3Village2Event,11,15)
	
	Armory(Ch3Armory,3,15)
	Vendor(Ch3Vendor,14,18)
	
	Seize(17,19)
	END_MAIN

Dunno1:

	END_MAIN

Dunno2:

	END_MAIN

Dunno3:

	END_MAIN

Tutorial:

	END_MAIN


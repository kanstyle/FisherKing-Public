StartEventRoutine:
	SetFlag(BleedoutFlag)
	ASMC ZeroInClearEffect|1
	ASMC BreezeChapterRepair|1
	SVAL 1 Loneliness //repair loneliness
	ASMC RepairSingleItem|1
	NoFade
	ENDA

Turn1Routine:
// Set Extended Destruction
	CHECK_EXISTS Bunny
	BEQ 0x0 0xC 0x0
		CHECK_DEPLOYED Bunny
		BEQ 0x0 0xC 0x0
			SetUnitStatus(Bunny,BadStatus,0x95) //special status for 9 turns, which ticks down to 8 when player phase starts
	LABEL 0x0
	NoFade
	ENDA

EndEventRoutine:
	DISA Sigil
	NoFade
	ENDA

BleedoutChapterAlwaysEvent:
	//ASMC ReviveAndSetPetrify|1
	NoFade
	ENDA

BleedoutChapterTurnEvent:
	CALL BleedoutTurnEvent
	NoFade
	ENDA

HeroGenderFlagTurnEvent:
	UnsetFlag(HeroGenderswapFlag)
	NoFade
	ENDA
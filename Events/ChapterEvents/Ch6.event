NPCUnits:
	UNIT

EnemyUnits:
	UNIT 0x81 Mercenary 0x40 Level(9,Enemy,True)     [12,11] 0b 0x0 0x0 0x0 [IronSword] AttackInRangeAI
	UNIT

Traps1:
	ENDTRAP
	ALIGN 4

Traps2:
	ENDTRAP
	ALIGN 4

BeginningScene:
	CALL StartEventRoutine
	
	FADI 4
	SetBackground(PillowKillCG)
	STAL 120
	CenterTextbox(Ch6PillowNarration)
	FADI 6
	CLEAN
	FADU 6
	
	FADI 16
	LOAD1 0x1 LionUnits
	LOAD1 0x1 EnemyUnits
	GotoPrepScreen
	ENDA
	
TeacherReinforcementsEvent:
	REVEAL Teacher
	REVEAL Storm
	REVEAL Gale
	CAM1 [16,2]
	STAL 60
	LOAD1 0x1 TeacherUnits
	Highlight(Teacher)
	
	NoFade
	ENDA

EndingScene:
	CALL EndEventRoutine
	MNC2 Ch0
	NoFade
	ENDA
HunterUnits:
	UNIT Hunter BowArmor 0x40 Level(6,Ally,False)     [17,14] 0b 0x0 0x1 REDA16R13 [HuntersBow,SteelBow,Vulnerary] [0x0,0x0,0x0,0x0]
	UNIT

Traps1:
	ENDTRAP
	ALIGN 4

Traps2:
	ENDTRAP
	ALIGN 4

BeginningScene:
	SetFlag(BleedoutFlag)
	
	CAMERA [3,1]
	LOAD2 0x1 UnitsSongbird
	ENUN
	FADU 6
	Highlight(Skull)
	Text(Ch2IntroSkullDialogue1)
	SetBackground(SongbirdHug)
	STAL 30
	CGText(Ch2IntroSkullHug1)
	CGText(Ch2IntroSkullHug2)
	CGText(Ch2IntroSkullHug3)
	CGText(Ch2IntroSkullHug4)
	RemoveBackground
	FADU 16
	Text(Ch2IntroSkullDialogue2)
	MOVE 8 Skull [17,3]
	MOVE 8 Pigeon [15,8]
	FADI 8
	ENUN
	DoAllThree
	
	CAMERA [17,12]
	FADU 3
	LOAD1 0x1 HunterUnits
	ENUN
	STAL 15
	Highlight(Hunter)
	Text(Ch2IntroHunter)
	CenterTextbox(Ch2IntroHunterNarration)
	STAL 15
	LOAD2 0x1 UnitsPillowStartEvent
	UNCM(Pillow,Hide)
	LOAD2 0x1 UnitsStartEvent
	ENUN
	STAL 30
	WARPIN [19,12]
	UNCR(Pillow,Hide)
	ENDWARP
	STAL 30
	
	Highlight(Dragon)
	SetBackground(LowlandForest)
	Text(Ch2IntroDragonConvo)
	RemoveBackground
	FADU 8
	LOAD2 0x1 EnemyUnitsStartEvent
	ENUN
	Text(Ch2IntroEnemiesSpawned)
	
	CAMERA [19,0]
	LOAD2 0x1 PigeonUnits
	ENUN
	Highlight(Pigeon)
	Text(Ch2IntroPigeon)
	FADI 16
	STAL 30
	
	DoAllThree
	LOAD1 0x1 EnemyUnits
	ENUN
	GotoPrepScreen
	GiveItem(Teacher,Butterfly)
	ENDA

EndingScene:
	MNC2 Ch0
	NoFade
	ENDA
	
Ch2HeroPigeonTalk:
	Text(Ch2HeroPigeonTalkText)
	CUSA(Pigeon)
	NoFade
	ENDA
	
Ch2BrotherPigeonTalk:
	Text(Ch2BrotherPigeonTalkText)
	CUSA(Pigeon)
	NoFade
	ENDA

Ch2TentEvent:
	SetBackground(TentBG)
	CenterTextbox(Ch2TentText)
	GiveItem(SteelLance,0xFFFF)
	RemoveBackground
	NoFade
	ENDA

Ch2VillageEvent:
	FADI 16
	SetBackground(TentBG)
	CenterTextbox(Ch2NorthHouseIntro)
	RemoveBackgroundFast
	SetBackground(BlackBG)
	CallMenu(Ch2VillageMenu)
		BNE 0x1 0xC 0x0
		SetBackground(TentBG)
		CenterTextbox(Ch2NorthHouseGroupText)
		RemoveBackground
		FADU 16
		GiveItem(CrystalKnife,0xFFFF)
		GOTO 0x2
	LABEL 0x1
		SetBackground(TentBG)
		CenterTextbox(Ch2NorthHouseSingleText)
		RemoveBackground
		FADU 16
		GiveItem(Butterfly,0xFFFF)
		GOTO 0x2
	RemoveBackgroundSlow
	LABEL 0x2
	NoFade
	ENDA
	
Ch2HeroSongbirdTalkEvent:
	Text(Ch2HeroSongbirdTalk)
	NoFade
	ENDA
	
Ch2TeacherSongbirdTalkEvent:
	Text(Ch2TeacherSongbirdTalk)
	NoFade
	ENDA

BleedoutChapterAlwaysEvent:
	ASMC ReviveAndSetPetrify|1
	NoFade
	ENDA

BleedoutChapterTurnEvent:
	CALL BleedoutTurnEvent
	NoFade
	ENDA

HeroGenderFlagTurnEvent:
	UnsetFlag(HeroGenderswapFlag)
	NoFade
	ENDA
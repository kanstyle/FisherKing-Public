	CALL EndEventRoutine
	MNC2 Ch3
	NoFade
	ENDA
	
Ch2HeroPigeonTalk:
	Text(Ch2HeroPigeonTalkText)
	//SetFlag(PigeonHeroTalkFlag)
	CUSA(Pigeon)
	NoFade
	ENDA
	
Ch2BrotherPigeonTalk:
	Text(Ch2BrotherPigeonTalkText)
	//SetFlag(PigeonBrotherTalkFlag)
	CUSA(Pigeon)
	NoFade
	ENDA

Ch2TentEvent:
	SetBackground(TentBG)
	CenterTextbox(Ch2TentTextGeneric)
	RemoveBackground
	GiveItem(SteelBow,0xFFFF)
	NoFade
	ENDA

Ch2VillageEvent:
	FADI 16
	SetBackground(TentBG)
	CenterTextbox(Ch2NorthHouseIntro)
	RemoveBackgroundFast
	SetBackground(BlackBG)
	CallMenu(Ch2VillageMenu)
		BNE 0x1 0xC 0x0
		SetBackground(TentBG)
		CenterTextbox(Ch2NorthHouseGroupText)
		RemoveBackground
		FADU 16
		GiveItem(CrystalKnife,0xFFFF)
		GOTO 0x2
	LABEL 0x1
		SetBackground(TentBG)
		CenterTextbox(Ch2NorthHouseSingleText)
		RemoveBackground
		FADU 16
		GiveItem(Butterfly,0xFFFF)
		GOTO 0x2
	RemoveBackgroundSlow
	LABEL 0x2
	NoFade
	ENDA
	
Ch2HeroSongbirdTalkEvent:
	Text(Ch2HeroSongbirdTalk)
	STAL 60
	IfAliveDialog(Pigeon,Ch2PigeonNo,0x0)
	LABEL 0x0
	CALL EndingScene
	NoFade
	ENDA
	

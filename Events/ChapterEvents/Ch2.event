Traps2:
	ENDTRAP
	ALIGN 4

BeginningScene:
	CALL StartEventRoutine
	
	CAMERA [3,1]
	MusicChange(FFTAnxiety)
	LOAD2 0x1 UnitsSongbird
	ENUN
	FADU 6
	BROWNBOXTEXT Ch0LowlandBrownBox [8,8]
	Highlight(Pigeon)
	Text(Ch2IntroPigeonGuard)
	
	MOVE 8 Skull [4,2]
	ENUN
	Highlight(Skull)
	Text(Ch2IntroSkullDialogue1)
	SetBackground(SongbirdHug)
	MusicChange(0x777F)
	STAL 30
	CGText(Ch2IntroSkullHug1)
	CGText(Ch2IntroSkullHug2)
	CGText(Ch2IntroSkullHug3)
	CGText(Ch2IntroSkullHug4)
	RemoveBackground
	MusicChange(FFTAnxiety)
	FADU 16
	Text(Ch2IntroSkullDialogue2)
	STAL 30
	MOVE 8 Skull [5,1]
	ENUN
	DISA Skull
	STAL 30
	MOVE 8 Pigeon [15,8]
	STAL 40
	FADI 8
	ENUN
	DoAllThree
	
	CAMERA [17,12]
	MusicChange(PMDSteamCaveID)
	FADU 3
	LOAD1 0x1 HunterUnits
	ENUN
	STAL 15
	Highlight(Hunter)
	Text(Ch2IntroHunter)
	CenterTextbox(Ch2IntroHunterNarration)
	STAL 15
	LOAD2 0x1 UnitsPillowStartEvent
	UNCM(Pillow,Hide)
	LOAD2 0x1 UnitsStartEvent
	ENUN
	STAL 30
	WARPIN [19,12]
	UNCR(Pillow,Hide)
	ENDWARP
	STAL 30
	
	Highlight(Dragon)
	SetBackground(LowlandForest)
	Text(Ch2IntroDragonConvo)
	RemoveBackground
	FADU 8
	LOAD2 0x1 EnemyUnitsStartEvent
	ENUN
	Text(Ch2IntroEnemiesSpawned)
	
	CAMERA [19,0]
	STAL 30
	CameraCursorLocation(19,3,60)
	MusicChange(FFTAnxiety)
	SetBackground(LowlandForest)
	Text(Ch2IntroPigeonSkull)
	RemoveBackground
	FADU 16
	LOAD2 0x1 PigeonUnits
	ENUN
	Highlight(Pigeon)
	Text(Ch2IntroPigeon)
	FADI 16
	STAL 30
	
	DoAllThree
	LOAD1 0x1 EnemyUnits
	ENUN
	GotoPrepScreen
	ENDA

EndingScene:
	FADI 8
	MUSC 0x7FFF
	DoAllThree
	
	CAMERA [5,14]
	LOAD2 0x1 TeacherUnits
	FADU 8
	CenterTextbox(Ch2EndNarration)
	MOVE 10 Teacher [17,12]
	STAL 45
	FADI 8
	ENUN
	SetBackground(LowlandForest)
	MusicChange(SoftSwooshSoundEffect)
	Text(Ch2EndSongbirdTalk)
	RemoveBackgroundSlow
	FadeOutMusic
	DoAllThree
	
